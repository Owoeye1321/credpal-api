extends layouts/main

block content
  h2(style="color: #1E3A5F; margin: 20px 0px 0px 10px") Email Verification

  p(style="font-size: 16px; margin: 10px 0px 0px 10px") Hello#{name ? ' ' + name : ''},

  p(style="font-size: 16px; margin: 10px 0px 0px 10px") Your verification code is:

  .otp-code
    .code #{otp}

  .highlight-box
    p ⏰ This code will expire in
      strong 10 minutes
      | . Please do not share this code with anyone.

  p(style="font-size: 16px; margin: 0px 0px 0px 10px") If you did not request this, please ignore this email.

  p(style="font-size: 16px; margin: 30px 0px 30px 10px")
    | Best regards,
    br
    strong The CredPal Team
